# P0 Demo does not require any secret or network access.
SERVICE_NAME=xerp-demo
APP_MODE=offline-demo
# DATABASE_PATH=./data/demo.db

# Optional P1 model provider placeholders. P0 still uses DemoExtractor.
OPENAI_API_KEY=replace-with-api-key
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_MODEL=replace-with-model-name

# Optional P1 Feishu placeholders. The local replay adapter needs none of these.
FEISHU_APP_ID=replace-with-app-id
FEISHU_APP_SECRET=replace-with-app-secret
FEISHU_VERIFICATION_TOKEN=replace-with-verification-token
FEISHU_ENCRYPT_KEY=replace-with-encrypt-key
